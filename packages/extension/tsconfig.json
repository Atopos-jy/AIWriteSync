{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["vite/client", "chrome", "node"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@aiwritesync/core": ["../core/src"],
      "@aiwritesync/core/*": ["../core/src/*"]
    },
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true
  },
  "include": ["src/**/*", "platforms/**/*"],
  "exclude": ["node_modules", "dist"]
}
